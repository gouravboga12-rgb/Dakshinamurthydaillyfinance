{
  "version": 2,
  "installCommand": "npm install && cd admin-panel && npm install && cd ../customer-mobile && npm install --legacy-peer-deps",
  "buildCommand": "node start-all.js --build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/uploads/(.*)", "destination": "/api/index.ts" },
    { "source": "/admin/(.*)", "destination": "/admin/index.html" },
    { "source": "/((?!api|uploads|admin).*)", "destination": "/index.html" }
  ]
}
